target/
bin/*
!bin/filecheck
!bin/lit
.crates.toml
.crates2.json

# Docs platform ignores
.vscode/*
!.vscode/tasks.json
!.vscode/launch.json
.code
.idea
site/
venv/
env/
*.out
node_modules/
*DS_Store
._*
*.iml
*.masp
book/

# Ignore Cargo.lock in test projects, except the component fixtures that
# intentionally commit their lockfile for reproducible builds.
tests/**/Cargo.lock
!tests/fixtures/components/**/Cargo.lock

# fuzza-agent working notes — survive `cargo make fuzza-cov-clean` (which wipes
# target/fuzza-coverage), but are local scratch and not committed. The
# directory itself is kept (via .gitkeep) so it exists on a fresh checkout.
tools/fuzza-agent/scratch/*
!tools/fuzza-agent/scratch/.gitkeep
tools/fuzza-agent/__pycache__/

*.lit_test_times.txt*
