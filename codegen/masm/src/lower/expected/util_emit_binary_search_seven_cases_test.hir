builtin.function public extern("C") @util_emit_binary_search_seven_cases_test(%0: u32, %1: u32) -> u32 {
    %2 = scf.index_switch %0 <{ cases = !builtin.array_u32<0, 1, 2, 3, 4, 5, 6> }> default_region {
        %10 = arith.mul %0, %1 <{ overflow = !builtin.overflow<checked> }>;
        scf.yield %10;
    };
    builtin.ret %2;
};