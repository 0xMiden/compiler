builtin.function public extern("C") @util_emit_binary_search_single_case_test(%0: u32, %1: u32) -> u32 {
    %2 = scf.index_switch %0 
    case 0 {
        %3 = arith.constant 0 : u32;
        scf.yield %3 : (u32);
    }
    default {
        %4 = arith.mul %0, %1 <{ overflow = #builtin.overflow<checked> }>;
        scf.yield %4 : (u32);
    } : (u32);
    builtin.ret %2 : (u32);
};