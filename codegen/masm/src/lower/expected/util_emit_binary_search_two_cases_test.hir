builtin.function public extern("C") @util_emit_binary_search_two_cases_test(%0: u32, %1: u32) -> u32 {
    %2 = scf.index_switch %0 <{ cases = !builtin.array_u32<0, 1> }> default_region {
        %5 = arith.mul %0, %1 <{ overflow = !builtin.overflow<checked> }>;
        scf.yield %5;
    };
    builtin.ret %2;
};