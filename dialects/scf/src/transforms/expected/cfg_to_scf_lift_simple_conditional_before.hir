builtin.function public extern("C") @cfg_to_scf_lift_simple_conditional(%0: u32) -> u32 {
    %2 = arith.constant 0 : u32;
    %3 = arith.eq %0, %2;
    cf.cond_br %3 ^block1, ^block2 : (i1);
^block1:
    %4 = arith.incr %0;
    cf.br ^block3:(%4);
^block2:
    %5 = arith.mul %0, %0 <{ overflow = #builtin.overflow<checked> }>;
    cf.br ^block3:(%5);
^block3(%1: u32):
    builtin.ret %1 : (u32);
};