builtin.function public extern("C") @fold_redundant_yields_all_but_one_switch(%0: u32) -> u32 {
    %5 = test.constant 11 : u32;
    %6 = test.constant 22 : u32;
    %7 = test.constant 33 : u32;
    %13, %14, %15 = scf.index_switch %0 
    case 1 {
        scf.yield %5, %6, %7 : (u32, u32, u32);
    }
    case 2 {
        scf.yield %5, %6, %7 : (u32, u32, u32);
