builtin.function public extern("C") @fold_redundant_yields_all_if_switch(%0: u32) -> u32 {
    %3 = test.constant 11 : u32;
    %4 = test.constant 22 : u32;
    %12, %13 = scf.index_switch %0 
    case 1 {
        scf.yield %3, %4 : (u32, u32);
    }
    case 2 {
        %5 = test.constant 0 : u32;
        %6 = test.eq %0, %5;
        %14, %15 = scf.if %6 then {
            scf.yield %3, %4 : (u32, u32);
        } else {
            scf.yield %3, %4 : (u32, u32);
        } : (i1) -> (u32, u32);
        scf.yield %14, %15 : (u32, u32);
    }
    default {
        scf.yield %3, %4 : (u32, u32);
    } : (u32, u32);
    %7 = test.add %12, %13 <{ overflow = #builtin.overflow<checked> }>;
    builtin.ret %7 : (u32);
};