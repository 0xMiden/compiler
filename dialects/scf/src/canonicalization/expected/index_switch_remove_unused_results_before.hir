builtin.function public extern("C") @index_switch_remove_unused_results(%0: u32) -> u32 {
    %1 = test.constant 1 : u32;
    %2 = test.constant 2 : u32;
    %3 = test.constant 3 : u32;
    %4 = test.constant 4 : u32;
    %5, %6 = scf.index_switch %0
    case 1 {
        scf.yield %1, %2 : (u32, u32);
    }
    default {
        scf.yield %3, %4 : (u32, u32);
    } : (u32, u32);
    builtin.ret %6 : (u32);
};
