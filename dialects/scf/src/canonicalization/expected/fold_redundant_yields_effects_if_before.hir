builtin.function public extern("C") @fold_redundant_yields_effects_if(%0: u32, %1: ptr<u32, byte>) -> u32 {
    %3 = test.constant 11 : u32;
    %4 = test.constant 0 : u32;
    %5 = test.eq %0, %4;
    %8 = scf.if %5 then {
        scf.yield %3 : (u32);
    } else {
        test.store %1, %3 : (ptr<u32, byte>, u32);
        scf.yield %3 : (u32);
    } : (i1) -> (u32);
    builtin.ret %8 : (u32);
};