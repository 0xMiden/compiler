builtin.function public extern("C") @fold_redundant_yields_many_switch(%0: u32) -> u32 {
    %7 = "test.constant"() <{ value = !builtin.number<11> }> : () -> u32;
    %8 = "test.constant"() <{ value = !builtin.number<22> }> : () -> u32;
    %9 = "test.constant"() <{ value = !builtin.number<33> }> : () -> u32;
    %24, %25, %26, %27, %28 = scf.index_switch %0 <{ cases = !builtin.array_u32<1, 2, 3> }> default_region {
        %16 = "test.constant"() <{ value = !builtin.number<400> }> : () -> u32;
        %17 = "test.constant"() <{ value = !builtin.number<401> }> : () -> u32;
        scf.yield %7, %8, %16, %9, %17;
    };
    %18 = "test.add"(%24, %25) <{ overflow = !builtin.overflow<checked> }> : (u32, u32) -> u32;
    %19 = "test.add"(%18, %26) <{ overflow = !builtin.overflow<checked> }> : (u32, u32) -> u32;
    %20 = "test.add"(%19, %27) <{ overflow = !builtin.overflow<checked> }> : (u32, u32) -> u32;
    %21 = "test.add"(%20, %28) <{ overflow = !builtin.overflow<checked> }> : (u32, u32) -> u32;
    builtin.ret %21;
};