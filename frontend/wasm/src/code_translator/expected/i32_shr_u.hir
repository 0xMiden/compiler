builtin.function public extern("C") @test_wrapper() {
    %0 = arith.constant 2 : i32;
    %1 = arith.constant 1 : i32;
    %2 = hir.bitcast %0 <{ ty = #builtin.type<u32> }>;
    %3 = hir.bitcast %1 <{ ty = #builtin.type<u32> }>;
    %4 = arith.constant 31 : u32;
    %5 = arith.band %3, %4;
    %6 = arith.shr %2, %5;
    %7 = hir.bitcast %6 <{ ty = #builtin.type<i32> }>;
    cf.br ^block5;
^block5:
    builtin.ret;
};
