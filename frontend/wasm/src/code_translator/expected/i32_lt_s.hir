builtin.function public extern("C") @test_wrapper() {
    %0 = arith.constant 2 : i32;
    %1 = arith.constant 1 : i32;
    %2 = arith.lt %0, %1;
    %3 = "arith.zext"(%2) <{ ty = !builtin.type<u32> }> : i1 -> u32;
    %4 = hir.bitcast %3 <{ ty = !builtin.type<i32> }>;
    cf.br ^block5;
^block5:
    builtin.ret;
};
