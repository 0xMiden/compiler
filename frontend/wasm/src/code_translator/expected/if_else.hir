builtin.function public extern("C") @test_wrapper() {
    %0 = arith.constant 2 : i32;
    %1 = arith.constant 0 : i32;
    %2 = arith.neq %0, %1;
    cf.cond_br %2 ^block6, ^block8;
^block5:
    builtin.ret;
^block6:
    %4 = arith.constant 3 : i32;
    cf.br ^block7:(%4);
^block7(%3: i32):
    cf.br ^block5;
^block8:
    %5 = arith.constant 5 : i32;
    cf.br ^block7:(%5);
};
