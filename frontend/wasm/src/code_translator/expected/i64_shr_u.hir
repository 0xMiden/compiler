builtin.function public extern("C") @test_wrapper() {
    %0 = arith.constant 2 : i64;
    %1 = arith.constant 1 : i64;
    %2 = hir.bitcast %0 <{ ty = !builtin.type<u64> }>;
    %3 = hir.cast %1 <{ ty = !builtin.type<u32> }>;
    %4 = arith.shr %2, %3;
    %5 = hir.bitcast %4 <{ ty = !builtin.type<i64> }>;
    cf.br ^block5;
^block5:
    builtin.ret;
};
