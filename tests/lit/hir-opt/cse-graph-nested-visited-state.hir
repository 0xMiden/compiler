// RUN: hir-opt %s --pass-pipeline='builtin.module(cse)' | filecheck %s

// This regression covers uses nested under an already-visited graph operation. The then
// branch yields %3 before the duplicate constant is defined, but that use is nested inside
// the scf.if operation that CSE has already visited. Rewriting the nested yield would make
// the if result equal to the canonical constant, so the pass must keep the yield on %3 and
// leave the final store using the if result.
//
// CHECK-LABEL: builtin.module private @nested_graph_visited_state
// CHECK: [[ADDR:%\d+]] = arith.constant 0 : u32;
// CHECK-NEXT: [[PTR:%\d+]] = hir.int_to_ptr [[ADDR]]
// CHECK: [[CANONICAL:%\d+]] = arith.constant 1 : i32;
// CHECK-NEXT: hir.store [[PTR]], [[CANONICAL]]
// CHECK-NEXT: [[COND:%\d+]] = arith.constant 1 : i1;
// CHECK-NEXT: [[IF:%\d+]] = scf.if [[COND]] then {
// CHECK-NEXT: scf.yield [[DUP:%\d+]] : (i32);
// CHECK-NEXT: } else {
// CHECK-NEXT: scf.yield [[CANONICAL]] : (i32);
// CHECK-NEXT: } : (i1) -> (i32);
// CHECK-NEXT: [[DUP]] = arith.constant 1 : i32;
// CHECK-NEXT: hir.store [[PTR]], [[IF]]
// CHECK-NOT: hir.store [[PTR]], [[CANONICAL]]
builtin.module private @nested_graph_visited_state {
    %addr = arith.constant 0 : u32;
    %ptr = hir.int_to_ptr %addr <{ ty = #builtin.type<ptr<i32, byte>> }>;
    %0 = arith.constant 1 : i32;
    hir.store %ptr, %0 : (ptr<i32, byte>, i32);
    %1 = arith.constant 1 : i1;
    %2 = "scf.if"(%1) ({
        // This nested forward use has already been visited through the scf.if.
        scf.yield %3 : (i32);
    }, {
        scf.yield %0 : (i32);
    }) : (i1) -> (i32);
    %3 = arith.constant 1 : i32;
    // The expected output keeps this store on the if result, not on %0.
    hir.store %ptr, %2 : (ptr<i32, byte>, i32);
};
