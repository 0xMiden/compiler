// RUN: env CARGO_TARGET_DIR=%target_dir/lit/sdk-project cargo run --bin component-macro-invalid-argument --manifest-path %S/sdk-project/Cargo.toml 2>&1 | filecheck %s

// CHECK: error: `#[component]` only accepts arguments on the component trait declaration; declare sibling component dependencies as `#[component(package::Interface, ...)]` on the trait
// CHECK-NEXT:  --> {{.*\.rs}}:[[#%d,ERRLINE:]]:{{[0-9]+}}
// CHECK-NEXT:   |
// CHECK-NEXT: [[#ERRLINE]] | #[component(foo)]
// CHECK-NEXT:   | {{ +}}^^^
